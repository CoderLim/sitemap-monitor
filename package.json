{
  "name": "sitemap-monitor",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dashboard:dev": "npm --prefix dashboard run dev",
    "dashboard:build": "npm --prefix dashboard run build",
    "cf:build": "npm --prefix dashboard run build",
    "cf:deploy": "npm run cf:build && npm --prefix workers run deploy",
