# Dashboard auth — same as link-master admin password.
# Precedence: DASHBOARD_TOKEN > ACCESS_PASSWORD
# Locally, sitemap-monitor auto-loads ../link-master/.env.local when present.
#
# ACCESS_PASSWORD=
# DASHBOARD_TOKEN=
#
# Frontend build (Cloudflare / static hosting) — same value as ACCESS_PASSWORD:
# VITE_DASHBOARD_TOKEN=
#
# Cloudflare Worker also needs (reuse link-master GITHUB_TOKEN):
# GITHUB_TOKEN=
